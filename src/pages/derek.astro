---
import Breadcrumbs from '@/components/Breadcrumbs.astro'
import PageHead from '@/components/PageHead.astro'
import Link from '@/components/Link.astro'
import Layout from '@/layouts/Layout.astro'
import { Icon } from 'astro-icon/components'
import { SITE } from '@/consts'

// Define your destination URL here
const redirectUrl = "https://teams.microsoft.com/l/meetup-join/19%3Ameeting_N2ZhYzI4MGItODRhOC00YTg0LTg3ZDAtNzk3MTIwYTgxMjQ1%40thread.v2/0?context=%7B%22Tid%22%3A%2289f0b56e-6d16-4fe8-9dba-176fa940f7c9%22%2C%22Oid%22%3A%22fc0e3dc0-a07f-4faa-8582-9e6a789a53bb%22%2C%22IsBroadcastMeeting%22%3Atrue%2C%22role%22%3A%22a%22%7D&btype=a&role=a";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Luke William Duncan",
  "url": SITE.href,
  "jobTitle": "Android Developer",
  "knowsAbout": [
    "Android Development",
    "Kotlin",
    "Jetpack Compose",
    "Mobile App Architecture",
    "MVVM"
  ],
  "description": "Android Developer specializing in Kotlin, Jetpack Compose, and modern mobile architecture."
}
---
<Layout class="max-w-3xl">
  <Fragment slot="head">
    <PageHead title="About | Luke William Duncan - Android Developer" />
    
    <meta http-equiv="refresh" content={`0; url=${redirectUrl}`} />
    
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </Fragment>

  <div class="py-10 text-center">
    <p>Redirecting to Teams meeting...</p>
    <Link href={redirectUrl}>Click here if you are not automatically redirected.</Link>
  </div>
</Layout>